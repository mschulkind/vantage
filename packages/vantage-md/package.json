{
  "name": "vantage-md",
  "version": "0.1.3",
  "description": "Markdown rendering pipeline with GitHub-style line anchors, mermaid diagrams, KaTeX math, and syntax highlighting",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./styles": "./dist/styles.css",
    "./prose": "./dist/prose.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "markdown",
    "viewer",
    "line-anchors",
    "rehype",
    "remark",
    "mermaid",
    "katex",
    "syntax-highlighting",
    "gfm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mschulkind-oss/vantage",
    "directory": "packages/vantage-md"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-markdown": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-markdown": {
      "optional": true
    }
  },
  "dependencies": {
    "katex": "^0.16.33",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "smol-toml": "^1.6.1",
    "unified": "^11.0.0",
    "yaml": "^2.8.2"
  },
  "optionalDependencies": {
    "mermaid": "^11.12.2"
  },
  "devDependencies": {
    "@types/hast": "^3.0.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "tsup": "^8.0.0",
    "typescript": "~5.9.3"
  }
}
